<%- include ("partials/header.ejs") %>
    <!-- Content -->
    <section id="content">
      <div class="container py-3 px-2">
        <h1>Edit Entry 🛠️</h1>
        <hr>
        <!-- Edit Entry Form -->
        <form action="/updateEntry/<%- entry.id %>" method="POST">
        <!-- Book Title -->
        <div class="mb-3">
            <label class="form-label">Book Title</label>
            <input
            type="text"
            class="form-control"
            placeholder="Title of book read"
            name="title"
            value="<%- entry.title %>"
            />
        </div>
        <!-- OLID Number -->
        <div class="mb-3">
            <label class="form-label"
            >Book Cover --- Provide Open Book ID Number*</label
            >
            <input type="text" 
            placeholder="Ex. OL33225306M" 
            class="form-control"
            name="number"
            value="<%- entry.olid %>"
            />
            <div class="form-text">
            Only enter the OLID number in field. To get value search the
            <a href="https://openlibrary.org/">Open Library</a> database.
            </div>
        </div>
        <!-- Readers Score -->
        <div class="mb-3">
            <label class="form-label"
            >Score Out of 10</label
            >
            <input
            type="number"
            class="form-control"
            name="score"
            value="<%- entry.score %>"
            />
        </div>
        <!-- Date of Completion -->
        <div class="mb-3">
        <label class="form-label"
            >Date Completed (YYYY-MM-DD)</label
        >
        <input
            type="text"
            class="form-control"
            name="date"
            value="<%- entry.date %>"
        />
        </div>
        <!-- Readers Thoughts -->
        <div class="mb-3">
            <label class="form-label"
            >Your Thoughts</label
            >
            <textarea
                class="form-control"
                rows="10"
                cols="50"
                type="text"
                name="summary"
                placeholder="Your Thoughts..."
            ><%- entry.summary %></textarea>
        </div>
        <button type="submit" class="btn btn-primary" value="Submit">Submit</button>
        </form>
        <!-- Delete Entry -->
        <form action="/delete/<%- entry.id %>" method="POST">
          <button type="submit" class="btn btn-danger my-2" value="Submit">Delete</button>
        </form>
      </div>
    </section>
    <!-- Footer -->
    <section id="Footer">
      <div class="container">
        <footer
          class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top"
        >
          <div class="col-md-4 d-flex align-items-center">
            <span class="mb-3 mb-md-0 text-body-secondary"
              >© <%= new Date().getFullYear() %> Brian's Book Notes</span
            >
          </div>
        </footer>
      </div>
    </section>
  </body>
</html>
